# Variables requeridas por cjhirashi_web/settings/prod.py
# (Django las lee desde os.environ / os.getenv)

# --- Django ---
SECRET_KEY=CAMBIA_ESTA_SECRET_KEY_LARGA_Y_UNICA

# Selección de settings (recomendado en VPS/systemd)
PROJECT_NAME=cjhirashi-web
DOMAIN=dominio.com
APP_DIR=carperta/del/proyecto
DJANGO_SETTINGS_MODULE=cjhirashi_web.settings.prod

# --- PostgreSQL (producción) ---
# Nota: en prod.py se usan defaults para DB/USER/HOST/PORT,
# pero PASSWORD no tiene default útil, así que debes definirlo.
POSTGRES_DB=nobre_de_tu_base_de_datos
POSTGRES_USER=usuario_de_tu_base_de_datos
POSTGRES_PASSWORD=CAMBIA_ESTA_PASSWORD_LARGA
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432